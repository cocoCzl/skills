{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "match-analysis.schema.json",
  "title": "Match Analysis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixture",
    "home_xg",
    "away_xg",
    "bayesian_adjustments",
    "result_probabilities",
    "score_candidates",
    "model_confidence",
    "data_confidence",
    "reference_grade",
    "risk_points"
  ],
  "properties": {
    "fixture": { "type": "object" },
    "home_xg": { "type": "number", "minimum": 0 },
    "away_xg": { "type": "number", "minimum": 0 },
    "bayesian_adjustments": { "type": "array", "items": { "type": "string" } },
    "model_record": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "prior": {
          "type": "object",
          "additionalProperties": true,
          "required": ["prior_xg", "adjustments", "final_xg"],
          "properties": {
            "prior_xg": {
              "type": "object",
              "additionalProperties": false,
              "required": ["home_xg", "away_xg"],
              "properties": {
                "home_xg": { "type": "number", "minimum": 0 },
                "away_xg": { "type": "number", "minimum": 0 }
              }
            },
            "adjustments": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": ["code", "target", "delta"],
                "properties": {
                  "code": { "type": "string" },
                  "target": { "type": "string", "enum": ["home", "away", "total"] },
                  "delta": { "type": "number" },
                  "note": { "type": "string" }
                }
              }
            },
            "final_xg": {
              "type": "object",
              "additionalProperties": false,
              "required": ["home_xg", "away_xg"],
              "properties": {
                "home_xg": { "type": "number", "minimum": 0 },
                "away_xg": { "type": "number", "minimum": 0 }
              }
            }
          }
        },
        "grade": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "edge": { "type": ["number", "null"] },
            "value_label": { "type": "string" },
            "value_judgment_available": { "type": "boolean" },
            "reference_grade": { "type": "string", "enum": ["A", "B", "C", "Pass"] },
            "grade_caps": { "type": "array", "items": { "type": "string" } },
            "downgrade_reasons": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "result_probabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["home_win", "draw", "away_win"],
      "properties": {
        "home_win": { "type": "number", "minimum": 0, "maximum": 1 },
        "draw": { "type": "number", "minimum": 0, "maximum": 1 },
        "away_win": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "over_under_probabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "line": { "type": "number" },
        "over": { "type": "number", "minimum": 0, "maximum": 1 },
        "under": { "type": "number", "minimum": 0, "maximum": 1 },
        "push": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "score_candidates": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["score", "role"],
        "properties": {
          "score": { "type": "string", "pattern": "^[0-9]+:[0-9]+$" },
          "role": { "type": "string", "enum": ["primary", "secondary", "upset_aware"] },
          "probability": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
        }
      }
    },
    "model_confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "data_confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "reference_grade": { "type": "string", "enum": ["A", "B", "C", "Pass"] },
    "risk_points": { "type": "array", "items": { "type": "string" } }
  }
}
