{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "portfolio.schema.json",
  "title": "Portfolio",
  "type": "object",
  "additionalProperties": false,
  "required": ["matches", "correlation_notes", "ticket_tiers", "more_combination_candidates", "excluded_matches", "portfolio_risk_tier"],
  "properties": {
    "matches": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": { "type": "object" }
    },
    "correlation_notes": { "type": "array", "items": { "type": "string" } },
    "ticket_tiers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ticket_tier" }
    },
    "more_combination_candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/ticket_tier" }
    },
    "excluded_matches": { "type": "array", "items": { "type": "string" } },
    "portfolio_risk_tier": { "type": "string", "enum": ["low", "medium", "high"] }
  },
  "$defs": {
    "ticket_tier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "stake_label", "unit_count", "unit_price", "total_amount", "structure", "legs", "risk_tier", "value_judgment", "reason"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "stake_label": { "type": "string", "minLength": 1 },
        "unit_count": { "type": "integer", "minimum": 1 },
        "unit_price": { "type": "number", "exclusiveMinimum": 0 },
        "total_amount": { "type": "number", "exclusiveMinimum": 0 },
        "structure": { "type": "string", "minLength": 1 },
        "legs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["match", "market", "market_type", "market_available", "selection", "selection_basis", "score_coverage"],
            "properties": {
              "match": { "type": "string", "minLength": 1 },
              "market": { "type": "string", "minLength": 1 },
              "market_type": {
                "type": "string",
                "enum": ["ordinary_result", "handicap_result", "correct_score", "over_under", "total_goals", "mixed", "analysis_only"]
              },
              "market_available": { "type": "boolean" },
              "selection": { "type": "string", "minLength": 1 },
              "selection_basis": { "type": "string", "minLength": 1 },
              "score_coverage": {
                "type": "array",
                "maxItems": 4,
                "items": { "type": "string", "pattern": "^[0-9]+:[0-9]+$" }
              }
            }
          }
        },
        "risk_tier": { "type": "string", "enum": ["low", "medium", "high"] },
        "value_judgment": { "type": "string" },
        "reason": { "type": "string" }
      }
    }
  }
}
