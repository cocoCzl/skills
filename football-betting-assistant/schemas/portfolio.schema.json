{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "portfolio.schema.json",
  "title": "Portfolio",
  "type": "object",
  "additionalProperties": false,
  "required": ["matches", "correlation_notes", "main_variant", "conservative_variant", "aggressive_variant", "excluded_matches", "portfolio_risk_tier"],
  "properties": {
    "matches": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": { "type": "object" }
    },
    "correlation_notes": { "type": "array", "items": { "type": "string" } },
    "main_variant": { "$ref": "#/$defs/variant" },
    "conservative_variant": { "$ref": "#/$defs/variant" },
    "aggressive_variant": { "$ref": "#/$defs/variant" },
    "excluded_matches": { "type": "array", "items": { "type": "string" } },
    "portfolio_risk_tier": { "type": "string", "enum": ["low", "medium", "high"] }
  },
  "$defs": {
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "legs", "risk_tier", "value_judgment"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "legs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["match", "market", "selection", "score_coverage"],
            "properties": {
              "match": { "type": "string", "minLength": 1 },
              "market": { "type": "string", "minLength": 1 },
              "selection": { "type": "string", "minLength": 1 },
              "score_coverage": {
                "type": "array",
                "maxItems": 3,
                "items": { "type": "string", "pattern": "^[0-9]+:[0-9]+$" }
              }
            }
          }
        },
        "risk_tier": { "type": "string", "enum": ["low", "medium", "high"] },
        "value_judgment": { "type": "string" }
      }
    }
  }
}
