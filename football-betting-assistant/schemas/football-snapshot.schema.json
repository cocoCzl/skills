{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "football-snapshot.schema.json",
  "title": "Football Match Data Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": ["snapshot_id", "mode", "provider", "sport", "observed_at", "timezone", "sources", "matches"],
  "properties": {
    "snapshot_id": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "enum": ["china-lottery", "international-odds", "analysis-only"] },
    "provider": { "type": "string", "minLength": 1 },
    "sport": { "type": "string", "enum": ["football"] },
    "observed_at": { "type": "string", "format": "date-time" },
    "timezone": { "type": "string", "minLength": 1 },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    },
    "matches": {
      "type": "array",
      "items": { "$ref": "#/$defs/match" }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/error" }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url", "observed_at", "status"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "observed_at": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["ok", "blocked", "missing", "parse_failed", "stale"] },
        "raw_file": { "type": ["string", "null"] },
        "notes": { "type": "string" }
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["match_id", "match_no", "competition", "kickoff_time", "timezone", "home_team", "away_team", "team_type", "markets", "source", "data_confidence"],
      "properties": {
        "match_id": { "type": "string", "minLength": 1 },
        "provider_match_id": { "type": ["string", "null"] },
        "match_no": { "type": ["string", "null"] },
        "competition": { "type": "string", "minLength": 1 },
        "kickoff_time": { "type": "string", "format": "date-time" },
        "timezone": { "type": "string", "minLength": 1 },
        "home_team": { "type": "string", "minLength": 1 },
        "away_team": { "type": "string", "minLength": 1 },
        "venue_type": { "type": "string", "enum": ["home_away", "neutral", "unknown"] },
        "team_type": { "type": "string", "enum": ["club", "national", "unknown", "unsupported"] },
        "unsupported_reason": { "type": ["string", "null"] },
        "markets": {
          "type": "array",
          "items": { "$ref": "#/$defs/market" }
        },
        "source": { "$ref": "#/$defs/sourceRef" },
        "data_confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "notes": { "type": "string" }
      }
    },
    "market": {
      "type": "object",
      "additionalProperties": false,
      "required": ["market", "source_market_name", "availability", "selections"],
      "properties": {
        "market": {
          "type": "string",
          "enum": ["match_result", "handicap_match_result", "correct_score", "over_under", "total_goals", "unsupported_market"]
        },
        "source_market_name": { "type": "string", "minLength": 1 },
        "line": { "type": ["number", "string", "null"] },
        "availability": { "$ref": "#/$defs/availability" },
        "selections": {
          "type": "array",
          "items": { "$ref": "#/$defs/selection" }
        },
        "source": { "$ref": "#/$defs/sourceRef" },
        "notes": { "type": "string" }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "odds"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "odds": { "type": ["number", "null"], "exclusiveMinimum": 1 },
        "source_name": { "type": "string" },
        "available": { "type": "boolean" }
      }
    },
    "availability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason"],
      "properties": {
        "status": { "type": "string", "enum": ["available", "unavailable", "unknown", "parse_failed"] },
        "reason": { "type": "string", "enum": ["available", "not_offered", "source_missing", "waf_blocked", "parser_error", "stale_source", "unknown"] },
        "message": { "type": "string" }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url", "observed_at"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "observed_at": { "type": "string", "format": "date-time" }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "source": { "type": "string" }
      }
    }
  }
}
